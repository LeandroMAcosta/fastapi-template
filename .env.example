# App
DEBUG_MODE=True
ENVIRONMENT=local

# Database
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/app_db

# Auth
AUTH_JWT_SECRET=your-secret-key-change-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRATION_MINUTES=60

# CORS
FRONTEND_URL=http://localhost:3000

# Sentry (optional)
SENTRY_DSN=
