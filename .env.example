# App
DEBUG_MODE=True
ENVIRONMENT=local

# Database
DB_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app_db

# Auth
AUTH_JWT_SECRET=your-secret-key-change-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRATION_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRATION_DAYS=7

# CORS
FRONTEND_URL=http://localhost:3000

# Sentry (optional)
SENTRY_DSN=

# OpenTelemetry (optional — enabled automatically in docker-compose.observability.yml)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=fastapi-template
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLE_RATE=1.0
